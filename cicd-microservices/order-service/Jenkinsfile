pipeline {
    agent any

    environment {
        DOCKER_IMAGE = 'lokeshkdevops/order-service'
        SERVICE_PATH = 'cicd-microservices/order-service'
    }

    stages {

        stage('Checkout') {
            steps {
                checkout scm
                script {
                    env.GIT_SHORT_COMMIT = sh(
                        script: "git rev-parse --short HEAD",
                        returnStdout: true
                    ).trim()

                    env.DOCKER_TAG = "${env.GIT_SHORT_COMMIT}"
                }
                echo "Checked out commit: ${env.GIT_SHORT_COMMIT}"
            }
        }

        stage('Install Dependencies') {
            steps {
                dir("${SERVICE_PATH}") {
                    sh 'npm install'
                }
            }
        }

        stage('Run Tests') {
            steps {
                dir("${SERVICE_PATH}") {
                    sh 'npm test'
                }
            }
        }

        stage('Build Docker Image') {
            steps {
                dir("${SERVICE_PATH}") {
                    sh """
                    docker build -t ${DOCKER_IMAGE}:${DOCKER_TAG} \
                                 -t ${DOCKER_IMAGE}:latest .
                    """
                }
            }
        }

        stage('Push Docker Image') {
            steps {
                withCredentials([usernamePassword(
                    credentialsId: 'docker-hub-credentials',
                    usernameVariable: 'DOCKER_USER',
                    passwordVariable: 'DOCKER_PASS'
                )]) {
                    sh '''
                    echo $DOCKER_PASS | docker login -u $DOCKER_USER --password-stdin
                    docker push ${DOCKER_IMAGE}:${DOCKER_TAG}
                    docker push ${DOCKER_IMAGE}:latest
                    '''
                }
            }
        }

        stage('Deploy to Kubernetes') {
            steps {
                withCredentials([file(
                    credentialsId: 'kubeconfig-credentials',
                    variable: 'KUBECONFIG_FILE'
                )]) {
                    sh '''
                    export KUBECONFIG=$KUBECONFIG_FILE

                    echo "Updating order-service deployment..."

                    kubectl set image deployment/order-service \
                    order-service=${DOCKER_IMAGE}:${DOCKER_TAG} \
                    -n microservices

                    kubectl rollout status deployment/order-service \
                    -n microservices --timeout=120s
                    '''
                }
            }
        }

        stage('Verify Deployment') {
            steps {
                withCredentials([file(
                    credentialsId: 'kubeconfig-credentials',
                    variable: 'KUBECONFIG_FILE'
                )]) {
                    sh '''
                    export KUBECONFIG=$KUBECONFIG_FILE

                    kubectl get pods -n microservices -l app=order-service
                    kubectl get svc -n microservices -l app=order-service
                    '''
                }
            }
        }
    }

    post {
        success {
            echo 'Order Service pipeline completed successfully!'
        }
        failure {
            echo 'Order Service pipeline failed. Check logs.'
        }
        always {
            script {
                sh 'docker logout || true'
            }
            cleanWs()
        }
    }
}
